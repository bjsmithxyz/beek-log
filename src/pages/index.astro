---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkRow from '../components/WorkRow.astro';
import RollRow from '../components/RollRow.astro';
import { getWorkEntries, getPhotoRolls, byDateDesc } from '../lib/collections';

const recentWork = (await getWorkEntries()).sort(byDateDesc).slice(0, 8);
const recentRolls = (await getPhotoRolls()).sort(byDateDesc).slice(0, 5);
---

<BaseLayout>
  <section class="home">
    <div class="container">
      <header class="home-header">
        <p class="prompt">~/beek</p>
        <h1 class="home-name">beek</h1>
        <p class="home-role">tech guy & creative</p>
      </header>

      {recentRolls.length > 0 && (
        <section class="recent" aria-labelledby="rolls-heading">
          <div class="dir-header">
            <h2 id="rolls-heading" class="dir-path">rolls/</h2>
            <a href="/photos/" class="dir-link">view all →</a>
          </div>
          <div class="dir-list">
            {recentRolls.map(roll => (
              <RollRow roll={roll} />
            ))}
          </div>
        </section>
      )}

      {recentWork.length > 0 && (
        <section class="recent" aria-labelledby="recent-heading">
          <div class="dir-header">
            <h2 id="recent-heading" class="dir-path">recent/</h2>
            <a href="/work/" class="dir-link">view all →</a>
          </div>
          <div class="dir-list">
            {recentWork.map(work => (
              <WorkRow work={work} showDescription={false} />
            ))}
          </div>
        </section>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .home {
    padding: var(--space-10) 0 var(--space-16);
  }

  .home-header {
    margin-bottom: var(--space-8);
  }

  .prompt {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .home-name {
    font-size: var(--font-size-5xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-2);
    letter-spacing: -0.02em;
  }

  .home-role {
    font-size: var(--font-size-lg);
    color: var(--color-accent-primary);
    margin-bottom: var(--space-5);
  }

  .recent + .recent {
    margin-top: var(--space-10);
  }

  .dir-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-4);
    gap: var(--space-4);
  }

  .dir-path {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
    margin: 0;
  }

  .dir-link {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .dir-link:hover {
    color: var(--color-accent-primary);
  }

  .dir-list {
    border-top: 1px solid var(--color-border);
  }
</style>
