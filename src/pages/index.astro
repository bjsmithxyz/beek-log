---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkRow from '../components/WorkRow.astro';
import RollRow from '../components/RollRow.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work', ({ data }) => !data.draft);
const sortedWork = allWork.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentWork = sortedWork.slice(0, 8);

const allRolls = await getCollection('photos', ({ data }) => import.meta.env.DEV || !data.draft);
const recentRolls = allRolls.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 5);
---

<BaseLayout>
  <section class="home">
    <div class="container">
      <header class="home-header">
        <p class="prompt">~/beek</p>
        <h1 class="home-name">beek</h1>
        <p class="home-role">tech guy & creative</p>
        <p class="home-desc">
          Building things, creating stuff.<br />
          If I make something I like, I'll upload it here.
        </p>
      </header>

      <nav class="home-nav" aria-label="Primary">
        <a href="/work" class="nav-cmd">&gt; work</a>
        <a href="/photos" class="nav-cmd">&gt; photos</a>
        <a href="/about" class="nav-cmd">&gt; about</a>
      </nav>

      {recentRolls.length > 0 && (
        <section class="recent" aria-labelledby="rolls-heading">
          <div class="dir-header">
            <h2 id="rolls-heading" class="dir-path">rolls/</h2>
            <a href="/photos" class="dir-link">view all →</a>
          </div>
          <div class="dir-list">
            {recentRolls.map(roll => (
              <RollRow roll={roll} />
            ))}
          </div>
        </section>
      )}

      {recentWork.length > 0 && (
        <section class="recent" aria-labelledby="recent-heading">
          <div class="dir-header">
            <h2 id="recent-heading" class="dir-path">recent/</h2>
            <a href="/work" class="dir-link">view all →</a>
          </div>
          <div class="dir-list">
            {recentWork.map(work => (
              <WorkRow work={work} showDescription={false} />
            ))}
          </div>
        </section>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .home {
    padding: var(--space-10) 0 var(--space-16);
  }

  .home-header {
    margin-bottom: var(--space-8);
  }

  .prompt {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .home-name {
    font-size: var(--font-size-5xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-2);
    letter-spacing: -0.02em;
  }

  .home-role {
    font-size: var(--font-size-lg);
    color: var(--color-accent-primary);
    margin-bottom: var(--space-5);
  }

  .home-desc {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    max-width: 480px;
    margin: 0;
  }

  .home-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-cmd {
    display: inline-block;
    font-size: var(--font-size-lg);
    color: var(--color-text-primary);
    padding: var(--space-2) 0;
    transition: color var(--transition-fast), padding-left var(--transition-fast);
  }

  .nav-cmd:hover {
    color: var(--color-accent-primary);
    padding-left: var(--space-3);
  }

  .recent + .recent {
    margin-top: var(--space-10);
  }

  .dir-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-4);
    gap: var(--space-4);
  }

  .dir-path {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-muted);
    margin: 0;
  }

  .dir-link {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .dir-link:hover {
    color: var(--color-accent-primary);
  }

  .dir-list {
    border-top: 1px solid var(--color-border);
  }
</style>
