---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkRow from '../../components/WorkRow.astro';
import PageHeader from '../../components/PageHeader.astro';
import FilterBar from '../../components/FilterBar.astro';
import DirListHeader from '../../components/DirListHeader.astro';
import { getWorkEntries, byDateDesc } from '../../lib/collections';

const allWork = await getWorkEntries();
const sortedWork = allWork.sort(byDateDesc);
const categories = [...new Set(allWork.map(w => w.data.category))];

const LIST_COLS = '5rem 6.5rem 1fr auto 1.5rem';
---

<BaseLayout 
  title="work"
  description="collection of projects, artwork, and photography"
>
  <section class="work-page">
    <div class="container">
      <PageHeader
        prompt="~/beek/work"
        title="work/"
        description={`${sortedWork.length} entries — projects, art, photography`}
      />

      <FilterBar
        options={categories}
        rowSelector=".work-row[data-category]"
        filterAttr="data-category"
      />

      <DirListHeader
        columns={['type', 'date', 'name', 'description', '']}
        cols={LIST_COLS}
      />

      <div class="dir-list" id="work-list" style={`--dir-cols: ${LIST_COLS}`}>
        {sortedWork.map(work => (
          <WorkRow work={work} />
        ))}
      </div>

      {sortedWork.length === 0 && (
        <p class="empty-state">// no entries</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .work-page {
    padding: var(--space-10) 0 var(--space-16);
  }
</style>
