---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const work = await getCollection('work', ({ data }) => !data.draft);
  return work.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, date, category, tags, liveUrl, repoUrl, cover, images } = entry.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});

const categoryColors = {
  dev: 'var(--color-accent-tertiary)',
  art: 'var(--color-accent-secondary)',
  photography: 'var(--color-accent-primary)',
};
---

<BaseLayout title={title} description={description}>
  <article class="work-detail">
    <div class="container container-narrow">
      <!-- Back link -->
      <a href="/work" class="back-link">
        ← work/
      </a>
      
      <!-- Header -->
      <header class="article-header">
        <p class="file-path">work/{entry.slug}.md</p>
        <span class="category" style={`--category-color: ${categoryColors[category]}`}>
          [{category}]
        </span>
        <h1 class="title">{title}</h1>
        <p class="description">{description}</p>
        
        <div class="meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <div class="tags">
              {tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        
        {(liveUrl || repoUrl) && (
          <div class="links">
            {liveUrl && (
              <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="link-btn">
                view live →
              </a>
            )}
            {repoUrl && (
              <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="link-btn link-btn-secondary">
                source →
              </a>
            )}
          </div>
        )}
      </header>
      
      <!-- Cover Image -->
      {cover && (
        <div class="cover-image">
          <Image
            src={cover}
            alt={title}
            width={1200}
            height={800}
            class="cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      )}
      
      <!-- Content -->
      <div class="content prose">
        <Content />
      </div>
      
      <!-- Gallery -->
      {images && images.length > 0 && (
        <div class="gallery">
          <h2>gallery/</h2>
          <div class="gallery-grid">
            {images.map((img, i) => (
              <figure class="gallery-item" style={`animation-delay: ${0.4 + i * 0.1}s`}>
                <Image 
                  src={img.src} 
                  alt={img.alt}
                  width={800}
                  height={600}
                  class="gallery-image"
                  data-lightbox
                />
                {img.alt && <figcaption>{img.alt.split(' - ')[0]}</figcaption>}
              </figure>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
    
    <button class="lightbox-nav lightbox-prev" aria-label="Previous image">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    
    <button class="lightbox-nav lightbox-next" aria-label="Next image">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>

    <div class="lightbox-content">
      <img id="lightbox-img" src="" alt="" />
      <p id="lightbox-caption"></p>
    </div>
  </div>
</BaseLayout>

<script>
  function setupLightbox() {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxCaption = document.getElementById('lightbox-caption');
    const closeBtn = document.querySelector('.lightbox-close');
    const prevBtn = document.querySelector('.lightbox-prev');
    const nextBtn = document.querySelector('.lightbox-next');
    const galleryItems = document.querySelectorAll('[data-lightbox]') as NodeListOf<HTMLImageElement>;

    if (!lightbox || !lightboxImg || !lightboxCaption || !closeBtn || !prevBtn || !nextBtn) return;

    let currentIndex = 0;

    const updateLightbox = (index: number) => {
      currentIndex = index;
      const item = galleryItems[currentIndex];
      if (!item) return;

      lightboxImg.src = item.src;
      lightboxImg.alt = item.alt;
      lightboxCaption.textContent = item.alt.split(' - ')[0];
    };

    const navigate = (direction: number) => {
      let nextIndex = currentIndex + direction;
      if (nextIndex < 0) nextIndex = galleryItems.length - 1;
      if (nextIndex >= galleryItems.length) nextIndex = 0;
      updateLightbox(nextIndex);
    };

    galleryItems.forEach((item, index) => {
      item.addEventListener('click', () => {
        updateLightbox(index);
        lightbox.classList.add('active');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      });
    });

    const closeLightbox = () => {
      lightbox.classList.remove('active');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setTimeout(() => {
        lightboxImg.src = '';
      }, 300);
    };

    closeBtn.addEventListener('click', closeLightbox);
    prevBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      navigate(-1);
    });
    nextBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      navigate(1);
    });

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target === document.querySelector('.lightbox-content')) {
        closeLightbox();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('active')) return;
      
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });
  }

  document.addEventListener('astro:page-load', setupLightbox);
</script>

<style>
  .work-detail {
    padding: var(--space-8) 0 var(--space-16);
  }
  
  .back-link {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-6);
    transition: color var(--transition-fast);
  }
  
  .back-link:hover {
    color: var(--color-accent-primary);
  }

  .file-path {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }
  
  .article-header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }
  
  .category {
    display: inline-block;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--category-color);
    margin-bottom: var(--space-3);
  }
  
  .title {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-3);
  }
  
  .description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-4);
  }
  
  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
  
  .meta time {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    font-variant-numeric: tabular-nums;
  }
  
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  
  .tag {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    background: var(--color-bg-tertiary);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
  }
  
  .links {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  
  .link-btn {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    background: var(--color-bg-tertiary);
    color: var(--color-accent-primary);
    border: 1px solid var(--color-accent-primary);
    transition: all var(--transition-fast);
  }
  
  .link-btn:hover {
    background: var(--color-accent-primary);
    color: var(--color-bg-primary);
    box-shadow: var(--shadow-hard-accent);
  }
  
  .link-btn-secondary {
    color: var(--color-text-secondary);
    border-color: var(--color-border);
    background: var(--color-bg-secondary);
  }
  
  .link-btn-secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-strong);
    background: var(--color-bg-tertiary);
    box-shadow: var(--shadow-hard);
  }
  
  .cover-image {
    margin-bottom: var(--space-6);
    border: 1px solid var(--color-border);
  }
  
  .cover {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .content {
    margin-bottom: var(--space-8);
  }
  
  .prose {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }
  
  .prose :global(h2) {
    font-size: var(--font-size-xl);
    color: var(--color-text-primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }
  
  .prose :global(h3) {
    font-size: var(--font-size-lg);
    color: var(--color-text-primary);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }
  
  .prose :global(p) {
    margin-bottom: var(--space-4);
  }
  
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }
  
  .prose :global(li) {
    margin-bottom: var(--space-2);
  }
  
  .prose :global(strong) {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
  }
  
  .prose :global(a) {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  
  .prose :global(a:hover) {
    color: var(--color-text-primary);
  }
  
  .prose :global(img) {
    border: 1px solid var(--color-border);
    margin: var(--space-6) 0;
  }
  
  .gallery {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }
  
  .gallery h2 {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    font-weight: var(--font-weight-medium);
  }
  
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-3);
  }
  
  .gallery-item {
    margin: 0;
    border: 1px solid var(--color-border);
  }
  
  .gallery-image {
    width: 100%;
    height: auto;
    cursor: pointer;
  }
  
  .gallery-item figcaption {
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
  }

  /* Lightbox */
  :global(.lightbox) {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    padding: var(--space-8);
  }

  :global(.lightbox.active) {
    opacity: 1;
    pointer-events: auto;
  }

  :global(.lightbox-content) {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    transform: scale(0.95);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global(.lightbox.active .lightbox-content) {
    transform: scale(1);
  }

  :global(.lightbox-content img) {
    max-width: 100%;
    max-height: calc(90vh - 80px);
    object-fit: contain;
    border: 1px solid var(--color-border);
  }

  :global(.lightbox-content p) {
    color: white;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-medium);
    margin: 0;
    text-align: center;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  :global(.lightbox-close) {
    position: absolute;
    top: var(--space-8);
    right: var(--space-8);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    cursor: pointer;
    z-index: 10001;
    transition: all var(--transition-fast);
  }

  :global(.lightbox-close:hover) {
    background: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    color: var(--color-bg-primary);
  }

  :global(.lightbox-nav) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10001;
    transition: all var(--transition-base);
  }

  :global(.lightbox-nav:hover) {
    background: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    color: var(--color-bg-primary);
  }

  :global(.lightbox-prev) {
    left: var(--space-8);
  }

  :global(.lightbox-next) {
    right: var(--space-8);
  }

  @media (max-width: 768px) {
    :global(.lightbox) {
      padding: var(--space-4);
    }
    :global(.lightbox-close) {
      top: var(--space-4);
      right: var(--space-4);
      width: 40px;
      height: 40px;
      font-size: 1.5rem;
    }
    :global(.lightbox-nav) {
      width: 44px;
      height: 44px;
      background: rgba(0, 0, 0, 0.5);
      border-color: rgba(255, 255, 255, 0.2);
    }
    :global(.lightbox-prev) {
      left: var(--space-4);
    }
    :global(.lightbox-next) {
      right: var(--space-4);
    }
  }
</style>
