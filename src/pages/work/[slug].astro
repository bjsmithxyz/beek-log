---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const work = await getCollection('work');
  return work.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, date, category, tags, liveUrl, repoUrl, cover, images } = entry.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});

const categoryColors = {
  dev: 'var(--color-accent-tertiary)',
  art: 'var(--color-accent-secondary)',
  photography: 'var(--color-accent-primary)',
};
---

<BaseLayout title={title} description={description}>
  <article class="work-detail">
    <div class="container container-narrow">
      <!-- Back link -->
      <a href="/work" class="back-link animate-fade-in">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        back to work
      </a>
      
      <!-- Header -->
      <header class="article-header animate-fade-in" style="animation-delay: 0.1s">
        <span class="category" style={`--category-color: ${categoryColors[category]}`}>
          {category}
        </span>
        <h1 class="title">{title}</h1>
        <p class="description">{description}</p>
        
        <div class="meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <div class="tags">
              {tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        
        {(liveUrl || repoUrl) && (
          <div class="links">
            {liveUrl && (
              <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="link-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
                view live
              </a>
            )}
            {repoUrl && (
              <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="link-btn link-btn-secondary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                source
              </a>
            )}
          </div>
        )}
      </header>
      
      <!-- Cover Image -->
      {cover && (
        <div class="cover-image animate-fade-in" style="animation-delay: 0.2s">
          <Image 
            src={cover} 
            alt={title}
            width={1200}
            height={800}
            class="cover"
          />
        </div>
      )}
      
      <!-- Content -->
      <div class="content prose animate-fade-in" style="animation-delay: 0.3s">
        <Content />
      </div>
      
      <!-- Gallery -->
      {images && images.length > 0 && (
        <div class="gallery animate-fade-in" style="animation-delay: 0.4s">
          <h2>gallery</h2>
          <div class="gallery-grid">
            {images.map((img, i) => (
              <figure class="gallery-item" style={`animation-delay: ${0.4 + i * 0.1}s`}>
                <Image 
                  src={img.src} 
                  alt={img.alt}
                  width={800}
                  height={600}
                  class="gallery-image"
                  data-lightbox
                />
                {img.alt && <figcaption>{img.alt.split(' - ')[0]}</figcaption>}
              </figure>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
    
    <button class="lightbox-nav lightbox-prev" aria-label="Previous image">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    
    <button class="lightbox-nav lightbox-next" aria-label="Next image">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>

    <div class="lightbox-content">
      <img id="lightbox-img" src="" alt="" />
      <p id="lightbox-caption"></p>
    </div>
  </div>
</BaseLayout>

<script>
  function setupLightbox() {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxCaption = document.getElementById('lightbox-caption');
    const closeBtn = document.querySelector('.lightbox-close');
    const prevBtn = document.querySelector('.lightbox-prev');
    const nextBtn = document.querySelector('.lightbox-next');
    const galleryItems = document.querySelectorAll('[data-lightbox]') as NodeListOf<HTMLImageElement>;

    if (!lightbox || !lightboxImg || !lightboxCaption || !closeBtn || !prevBtn || !nextBtn) return;

    let currentIndex = 0;

    const updateLightbox = (index: number) => {
      currentIndex = index;
      const item = galleryItems[currentIndex];
      if (!item) return;

      lightboxImg.src = item.src;
      lightboxImg.alt = item.alt;
      lightboxCaption.textContent = item.alt.split(' - ')[0];
    };

    const navigate = (direction: number) => {
      let nextIndex = currentIndex + direction;
      if (nextIndex < 0) nextIndex = galleryItems.length - 1;
      if (nextIndex >= galleryItems.length) nextIndex = 0;
      updateLightbox(nextIndex);
    };

    galleryItems.forEach((item, index) => {
      item.addEventListener('click', () => {
        updateLightbox(index);
        lightbox.classList.add('active');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      });
    });

    const closeLightbox = () => {
      lightbox.classList.remove('active');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setTimeout(() => {
        lightboxImg.src = '';
      }, 300);
    };

    closeBtn.addEventListener('click', closeLightbox);
    prevBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      navigate(-1);
    });
    nextBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      navigate(1);
    });

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target === document.querySelector('.lightbox-content')) {
        closeLightbox();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('active')) return;
      
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });
  }

  document.addEventListener('astro:page-load', setupLightbox);
</script>

<style>
  .work-detail {
    padding: var(--space-8) 0 var(--space-16);
  }
  
  /* Back Link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-8);
    transition: all var(--transition-fast);
  }
  
  .back-link:hover {
    color: var(--color-accent-primary);
    gap: var(--space-3);
  }
  
  .back-link svg {
    transition: transform var(--transition-fast);
  }
  
  .back-link:hover svg {
    transform: translateX(-4px);
  }
  
  /* Header */
  .article-header {
    margin-bottom: var(--space-8);
  }
  
  .category {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: lowercase;
    letter-spacing: 0.02em;
    color: var(--category-color);
    margin-bottom: var(--space-3);
  }
  
  .title {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-4);
  }
  
  .description {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-5);
  }
  
  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }
  
  .meta time {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }
  
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  
  .tag {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    background: var(--color-bg-tertiary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }
  
  .links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  
  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    background: var(--color-accent-primary);
    color: white;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }
  
  .link-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
    color: white;
  }
  
  .link-btn-secondary {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
  }
  
  .link-btn-secondary:hover {
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    box-shadow: var(--shadow-md);
  }
  
  /* Cover Image */
  .cover-image {
    margin-bottom: var(--space-8);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  
  .cover {
    width: 100%;
    height: auto;
    display: block;
  }
  
  /* Content */
  .content {
    margin-bottom: var(--space-10);
  }
  
  .prose {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }
  
  .prose :global(h2) {
    font-size: var(--font-size-2xl);
    color: var(--color-text-primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }
  
  .prose :global(h3) {
    font-size: var(--font-size-xl);
    color: var(--color-text-primary);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }
  
  .prose :global(p) {
    margin-bottom: var(--space-4);
  }
  
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }
  
  .prose :global(li) {
    margin-bottom: var(--space-2);
  }
  
  .prose :global(strong) {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
  }
  
  .prose :global(a) {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  
  .prose :global(a:hover) {
    color: var(--color-accent-secondary);
  }
  
  .prose :global(img) {
    border-radius: var(--radius-md);
    margin: var(--space-6) 0;
  }
  
  /* Gallery */
  .gallery {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-8);
  }
  
  .gallery h2 {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-6);
  }
  
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-4);
  }
  
  .gallery-item {
    margin: 0;
    animation: fadeInUp var(--transition-slow) forwards;
    opacity: 0;
  }
  
  .gallery-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    transition: transform var(--transition-base);
  }
  
  .gallery-item:hover .gallery-image {
    transform: scale(1.02);
  }
  
  .gallery-item figcaption {
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  .gallery-image {
    cursor: pointer;
  }

  /* Lightbox */
  :global(.lightbox) {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    padding: var(--space-8);
  }

  :global(.lightbox.active) {
    opacity: 1;
    pointer-events: auto;
  }

  :global(.lightbox-content) {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    transform: scale(0.95);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global(.lightbox.active .lightbox-content) {
    transform: scale(1);
  }

  :global(.lightbox-content img) {
    max-width: 100%;
    max-height: calc(90vh - 80px);
    object-fit: contain;
    border-radius: var(--radius-sm);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  :global(.lightbox-content p) {
    color: white;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-medium);
    margin: 0;
    text-align: center;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  :global(.lightbox-close) {
    position: absolute;
    top: var(--space-8);
    right: var(--space-8);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    cursor: pointer;
    z-index: 10001;
    transition: all var(--transition-fast);
  }

  :global(.lightbox-close:hover) {
    background: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    transform: rotate(90deg);
  }

  :global(.lightbox-nav) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10001;
    transition: all var(--transition-base);
  }

  :global(.lightbox-nav:hover) {
    background: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    transform: translateY(-50%) scale(1.1);
  }

  :global(.lightbox-prev) {
    left: var(--space-8);
  }

  :global(.lightbox-next) {
    right: var(--space-8);
  }

  @media (max-width: 768px) {
    :global(.lightbox) {
      padding: var(--space-4);
    }
    :global(.lightbox-close) {
      top: var(--space-4);
      right: var(--space-4);
      width: 40px;
      height: 40px;
      font-size: 1.5rem;
    }
    :global(.lightbox-nav) {
      width: 44px;
      height: 44px;
      background: rgba(0, 0, 0, 0.5);
      border-color: rgba(255, 255, 255, 0.2);
    }
    :global(.lightbox-prev) {
      left: var(--space-4);
    }
    :global(.lightbox-next) {
      right: var(--space-4);
    }
  }
</style>
