---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { Image } from 'astro:assets';
import { render, type CollectionEntry } from 'astro:content';
import { getWorkEntries, byDateDesc } from '../../lib/collections';
import { formatLongDate } from '../../lib/dates';

export async function getStaticPaths() {
  const sorted = (await getWorkEntries()).sort(byDateDesc);
  const neighbor = (e: CollectionEntry<'work'>) => ({ slug: e.id, title: e.data.title });
  return sorted.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      newer: i > 0 ? neighbor(sorted[i - 1]) : null,
      older: i < sorted.length - 1 ? neighbor(sorted[i + 1]) : null,
    },
  }));
}

interface Props {
  entry: CollectionEntry<'work'>;
  newer: { slug: string; title: string } | null;
  older: { slug: string; title: string } | null;
}

const { entry, newer, older } = Astro.props;
const { Content } = await render(entry);
const { title, description, date, category, tags, liveUrl, repoUrl, cover, images } = entry.data;

const formattedDate = formatLongDate(date);
const categoryClass = `tag-${category}`;

const ogImage = `/og/work/${entry.id}.png`;
const jsonLd = {
  '@type': 'CreativeWork',
  name: title,
  description,
  datePublished: date.toISOString(),
  url: new URL(`/work/${entry.id}/`, Astro.site).href,
  image: new URL(ogImage, Astro.site).href,
  ...(repoUrl ? { codeRepository: repoUrl } : {}),
};
---

<BaseLayout title={title} description={description} image={ogImage} jsonLd={jsonLd}>
  <article class="work-detail">
    <div class="container container-narrow">
      <a href="/work/" class="back-link">
        ← work/
      </a>
      
      <header class="article-header">
        <p class="file-path">work/{entry.id}.md</p>
        <span class={`category ${categoryClass}`}>[{category}]</span>
        <h1 class="title">{title}</h1>
        <p class="description">{description}</p>
        
        <div class="meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <div class="tags">
              {tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        
        {(liveUrl || repoUrl) && (
          <div class="links">
            {liveUrl && (
              <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="link-btn">
                view live →
              </a>
            )}
            {repoUrl && (
              <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="link-btn link-btn-secondary">
                source →
              </a>
            )}
          </div>
        )}
      </header>
      
      {cover && (
        <div class="cover-image">
          <Image
            src={cover}
            alt={title}
            width={1200}
            height={800}
            class="cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      )}
      
      <div class="content prose">
        <Content />
      </div>
      
      {images && images.length > 0 && (
        <div class="gallery">
          <h2>gallery/</h2>
          <div class="gallery-grid">
            {images.map((img, i) => (
              <figure class="gallery-item">
                <Image 
                  src={img.src} 
                  alt={img.alt}
                  width={800}
                  height={600}
                  class="gallery-image"
                  data-lightbox
                  data-lightbox-id={`img-${i}`}
                />
                {img.alt && <figcaption>{img.alt.split(' - ')[0]}</figcaption>}
              </figure>
            ))}
          </div>
        </div>
      )}

      {(newer || older) && (
        <nav class="project-nav" aria-label="More work">
          {newer ? (
            <a href={`/work/${newer.slug}/`} class="project-nav-link prev">
              <span class="project-nav-dir">← newer</span>
              <span class="project-nav-title">{newer.title}</span>
            </a>
          ) : <span />}
          {older ? (
            <a href={`/work/${older.slug}/`} class="project-nav-link next">
              <span class="project-nav-dir">older →</span>
              <span class="project-nav-title">{older.title}</span>
            </a>
          ) : <span />}
        </nav>
      )}
    </div>
  </article>

  <Lightbox />
</BaseLayout>

<style>
  .work-detail {
    padding: var(--space-8) 0 var(--space-16);
  }
  
  .category {
    display: inline-block;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    margin-bottom: var(--space-3);
  }
  
  .description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-4);
  }
  
  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
  
  .meta time {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    font-variant-numeric: tabular-nums;
  }
  
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  
  .tag {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    background: var(--color-bg-tertiary);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
  }
  
  .links {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  
  .link-btn {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    background: var(--color-bg-tertiary);
    color: var(--color-accent-primary);
    border: 1px solid var(--color-accent-primary);
    transition: all var(--transition-fast);
  }
  
  .link-btn:hover {
    background: var(--color-accent-primary);
    color: var(--color-bg-primary);
    box-shadow: var(--shadow-hard-accent);
  }
  
  .link-btn-secondary {
    color: var(--color-text-secondary);
    border-color: var(--color-border);
    background: var(--color-bg-secondary);
  }
  
  .link-btn-secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-strong);
    background: var(--color-bg-tertiary);
    box-shadow: var(--shadow-hard);
  }
  
  .cover-image {
    margin-bottom: var(--space-6);
    border: 1px solid var(--color-border);
  }
  
  .cover {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .content {
    margin-bottom: var(--space-8);
  }
  
  .gallery {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }
  
  .gallery h2 {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    font-weight: var(--font-weight-medium);
  }
  
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-3);
  }
  
  .gallery-item {
    margin: 0;
    border: 1px solid var(--color-border);
  }
  
  .gallery-image {
    width: 100%;
    height: auto;
    cursor: pointer;
  }
  
  .gallery-item figcaption {
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
  }

  .project-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .project-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
    transition: all var(--transition-fast);
  }

  .project-nav-link.next {
    text-align: right;
  }

  .project-nav-link:hover {
    border-color: var(--color-accent-primary);
    box-shadow: var(--shadow-hard-accent);
  }

  .project-nav-dir {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .project-nav-link:hover .project-nav-dir {
    color: var(--color-accent-primary);
  }

  .project-nav-title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .project-nav {
      grid-template-columns: 1fr;
    }
    .project-nav-link.next {
      text-align: left;
    }
  }
</style>
