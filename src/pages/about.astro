---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="about"
  description="who?"
>
  <section class="about-page">
    <div class="container container-narrow">
      <header class="page-header animate-fade-in">
        <h1 class="page-title">about</h1>
      </header>
      
      <div class="about-content">
        
        <div class="bio animate-fade-in" style="animation-delay: 0.2s">
          <p>
          My name is <span class="highlight">beek</span>. If I make something, I'll upload it here.
          </p>
          <p>
            I'm a creative and tech enthusiast based in Australia. I enjoy building technical projects and creating art, sometimes the two intersect.
          </p>
          <p>
            You can find me on  
            <a href="https://github.com/bjsmithxyz/" target="_blank" rel="noopener noreferrer" class="social-inline-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a> 
            and  
            <a href="https://www.instagram.com/bjsmith.xyz/" target="_blank" rel="noopener noreferrer" class="social-inline-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              Instagram
            </a>.
          </p>
        </div>
        <div class="tagline animate-fade-in" style="animation-delay: 0.4s">
          <blockquote>
            Be excellent to each other.
          </blockquote>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    padding: var(--space-12) 0 var(--space-16);
  }
  
  .page-header {
    margin-bottom: var(--space-10);
  }
  
  .page-title {
    font-size: var(--font-size-5xl);
  }
  
  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  
  .intro {
    margin-bottom: var(--space-4);
  }
  
  .lead {
    font-size: var(--font-size-2xl);
    color: var(--color-text-primary);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }
  
  .highlight {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: var(--font-weight-medium);
  }
  
  .bio p {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }
  
  .connect h2 {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-3);
  }
  
  .connect p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }
  
  .social-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  
  .social-inline-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-accent-primary);
    font-weight: var(--font-weight-medium);
    transition: all var(--transition-fast);
    text-decoration: none;
    vertical-align: middle;
  }

  .social-inline-link:hover {
    color: var(--color-accent-secondary);
    transform: translateY(-1px);
  }

  .social-inline-link svg {
    flex-shrink: 0;
  }

  .social-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    transition: all var(--transition-fast);
    width: fit-content;
  }
  
  .social-item:hover {
    border-color: var(--color-accent-primary);
    transform: translateX(4px);
  }
  
  .social-item svg {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }
  
  .social-item:hover svg {
    color: var(--color-accent-primary);
  }
  
  .tagline {
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }
  
  .tagline blockquote {
    font-size: var(--font-size-2xl);
    font-style: italic;
    font-weight: var(--font-weight-light);
    color: var(--color-text-secondary);
    margin: 0;
    padding-left: var(--space-5);
    border-left: 3px solid var(--color-accent-primary);
  }
</style>
