---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RollRow from '../../components/RollRow.astro';
import WorldMap from '../../components/WorldMap.astro';
import PageHeader from '../../components/PageHeader.astro';
import FilterBar from '../../components/FilterBar.astro';
import DirListHeader from '../../components/DirListHeader.astro';
import { getPhotoRolls, byDateDesc } from '../../lib/collections';
import { aggregatePins } from '../../data/locations';

const sortedRolls = (await getPhotoRolls()).sort(byDateDesc);

const totalFrames = sortedRolls.reduce((sum, r) => sum + r.data.photos.length, 0);
const years = [...new Set(sortedRolls.map((r) => r.data.date.getFullYear().toString()))];

const pins = aggregatePins(sortedRolls);

const LIST_COLS = '12rem 6.5rem 1fr 11rem 1.5rem';
---

<BaseLayout
  title="photos"
  description="film photography by roll — contact sheets, stocks, and shoot locations"
>
  <section class="photos-page">
    <div class="container">
      <PageHeader
        prompt="~/beek/photos"
        title="photos/"
        description={`${sortedRolls.length} ${sortedRolls.length === 1 ? 'roll' : 'rolls'} — ${totalFrames} frames · ${pins.length} ${pins.length === 1 ? 'location' : 'locations'}`}
      />

      {pins.length > 0 && (
        <div class="map-section">
          <h2 class="section-label">map/</h2>
          <WorldMap pins={pins} />
        </div>
      )}

      {years.length > 1 && (
        <FilterBar
          options={years}
          rowSelector=".roll-row[data-year]"
          filterAttr="data-year"
        />
      )}

      <DirListHeader
        columns={['film', 'date', 'roll', 'location', '']}
        cols={LIST_COLS}
      />

      <div class="dir-list" id="roll-list" style={`--dir-cols: ${LIST_COLS}`}>
        {sortedRolls.map((roll) => (
          <RollRow roll={roll} />
        ))}
      </div>

      {sortedRolls.length === 0 && (
        <p class="empty-state">// no rolls yet — film's still at the lab</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .photos-page {
    padding: var(--space-10) 0 var(--space-16);
  }

  .map-section {
    margin-bottom: var(--space-6);
  }

  .section-label {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
    font-weight: var(--font-weight-medium);
  }
</style>
