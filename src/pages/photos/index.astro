---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RollRow from '../../components/RollRow.astro';
import WorldMap, { type Pin } from '../../components/WorldMap.astro';
import { getCollection } from 'astro:content';

// drafts render in dev for previewing, never in production builds
const rolls = await getCollection('photos', ({ data }) => import.meta.env.DEV || !data.draft);
const sortedRolls = rolls.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalFrames = sortedRolls.reduce((sum, r) => sum + r.data.photos.length, 0);
const years = [...new Set(sortedRolls.map((r) => r.data.date.getFullYear().toString()))];

// one pin per location, anchored to the most recent roll shot there
const pinMap = new Map<string, Pin>();
for (const roll of sortedRolls) {
  const { name, lat, lng } = roll.data.location;
  const existing = pinMap.get(name);
  if (existing) {
    existing.count += 1;
  } else {
    pinMap.set(name, { slug: roll.slug, name, lat, lng, count: 1 });
  }
}
const pins = [...pinMap.values()];
---

<BaseLayout
  title="photos"
  description="film photography by roll — contact sheets, stocks, and shoot locations"
>
  <section class="photos-page">
    <div class="container">
      <header class="page-header">
        <p class="prompt">~/beek/photos</p>
        <h1 class="page-title">photos/</h1>
        <p class="page-description">
          {sortedRolls.length} {sortedRolls.length === 1 ? 'roll' : 'rolls'} — {totalFrames} frames · {pins.length} {pins.length === 1 ? 'location' : 'locations'}
        </p>
      </header>

      {pins.length > 0 && (
        <div class="map-section">
          <h2 class="section-label">map/</h2>
          <WorldMap pins={pins} />
        </div>
      )}

      {years.length > 1 && (
        <div class="filters">
          <button class="filter-btn active" data-filter="all">[all]</button>
          {years.map((year) => (
            <button class="filter-btn" data-filter={year}>[{year}]</button>
          ))}
        </div>
      )}

      <div class="list-header" aria-hidden="true">
        <span>film</span>
        <span>date</span>
        <span>roll</span>
        <span>location</span>
        <span>#</span>
        <span></span>
      </div>

      <div class="dir-list" id="roll-list">
        {sortedRolls.map((roll) => (
          <RollRow roll={roll} />
        ))}
      </div>

      {sortedRolls.length === 0 && (
        <p class="empty-state">// no rolls yet — film's still at the lab</p>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  function setupRollFilters() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const rollRows = document.querySelectorAll('.roll-row[data-year]');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.getAttribute('data-filter');

        rollRows.forEach(row => {
          const year = row.getAttribute('data-year');
          const isMatch = filter === 'all' || year === filter;
          (row as HTMLElement).style.display = isMatch ? 'grid' : 'none';
        });
      });
    });
  }

  document.addEventListener('astro:page-load', setupRollFilters);
</script>

<style>
  .photos-page {
    padding: var(--space-10) 0 var(--space-16);
  }

  .page-header {
    margin-bottom: var(--space-6);
  }

  .prompt {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .page-title {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-2);
  }

  .page-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .map-section {
    margin-bottom: var(--space-6);
  }

  .section-label {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
    font-weight: var(--font-weight-medium);
  }

  .filters {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    font-family: inherit;
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text-primary);
  }

  .filter-btn.active {
    background: var(--color-bg-tertiary);
    border-color: var(--color-accent-primary);
    color: var(--color-accent-primary);
    box-shadow: var(--shadow-hard-accent);
  }

  .list-header {
    display: grid;
    grid-template-columns: 12rem 6.5rem 1fr auto 3rem 1.5rem;
    gap: var(--space-4);
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--color-border);
    background: var(--color-bg-tertiary);
  }

  .dir-list {
    /* rows handle their own borders */
  }

  .empty-state {
    padding: var(--space-8);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    border: 1px solid var(--color-border);
    margin-top: var(--space-4);
  }

  @media (max-width: 768px) {
    .list-header {
      display: none;
    }
  }
</style>
