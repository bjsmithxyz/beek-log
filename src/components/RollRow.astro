---
import type { CollectionEntry } from 'astro:content';
import { getFilmStock } from '../data/film-stocks';
import { effectiveLocations } from '../data/locations';

interface Props {
  roll: CollectionEntry<'photos'>;
}

const { roll } = Astro.props;
const { title, stock, date, location } = roll.data;
const film = getFilmStock(stock);
const locCount = effectiveLocations(roll).length;
const locLabel = locCount > 1 ? `${location.name} +${locCount - 1}` : location.name;

const formattedDate = date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
const year = date.getFullYear().toString();
---

<a
  href={`/photos/${roll.id}/`}
  class="roll-row"
  id={`roll-${roll.id}`}
  data-year={year}
  data-slug={roll.id}
>
  <span class="row-stock" data-type={film.type}>[{film.name}]</span>
  <span class="row-date">{formattedDate}</span>
  <span class="row-title">{title}</span>
  <span class="row-location">{locLabel}</span>
  <span class="row-arrow" aria-hidden="true">→</span>
</a>

<style>
  .roll-row {
    display: grid;
    grid-template-columns: 12rem 6.5rem 1fr 11rem 1.5rem;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    margin-top: -1px;
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: background var(--transition-fast);
    scroll-margin-top: var(--space-16);
  }

  .roll-row:first-child {
    margin-top: 0;
  }

  .roll-row:hover {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
  }

  .roll-row:hover .row-arrow {
    color: var(--color-accent-primary);
  }

  /* map pin jump target */
  .roll-row:target {
    border-color: var(--color-accent-primary);
    box-shadow: var(--shadow-hard-accent);
  }

  /* highlighted from hovering its pin on the map */
  .roll-row.is-pin-active {
    border-color: var(--color-accent-primary);
    outline: 1px solid var(--color-accent-primary);
  }

  .row-stock {
    font-weight: var(--font-weight-medium);
    color: var(--color-accent-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .row-stock[data-type='bw'] {
    color: var(--color-text-secondary);
  }

  .row-date {
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .row-title {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .row-location {
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .row-arrow {
    color: var(--color-text-muted);
    text-align: right;
    transition: color var(--transition-fast);
  }

  @media (max-width: 768px) {
    .roll-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto auto;
      gap: var(--space-1) var(--space-3);
    }

    .row-stock,
    .row-date {
      grid-row: 1;
    }

    .row-date {
      justify-self: end;
    }

    .row-title {
      grid-column: 1 / -1;
    }

    .row-location {
      grid-row: 3;
      grid-column: 1 / -1;
    }

    .row-arrow {
      display: none;
    }
  }
</style>
