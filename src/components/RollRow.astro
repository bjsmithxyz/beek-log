---
import type { CollectionEntry } from 'astro:content';
import { getFilmStock } from '../data/film-stocks';
import { effectiveLocations } from '../data/locations';
import { formatListDate } from '../lib/dates';

interface Props {
  roll: CollectionEntry<'photos'>;
}

const { roll } = Astro.props;
const { title, stock, date, location } = roll.data;
const film = getFilmStock(stock);
const locCount = effectiveLocations(roll).length;
const locLabel = locCount > 1 ? `${location.name} +${locCount - 1}` : location.name;

const formattedDate = formatListDate(date);
const year = date.getFullYear().toString();
---

<a
  href={`/photos/${roll.id}/`}
  class="dir-row roll-row"
  id={`roll-${roll.id}`}
  data-year={year}
  data-slug={roll.id}
>
  <span class="row-stock" data-type={film.type}>[{film.name}]</span>
  <span class="row-date">{formattedDate}</span>
  <span class="row-title">{title}</span>
  <span class="row-location">{locLabel}</span>
  <span class="row-arrow" aria-hidden="true">→</span>
</a>

<style>
  .roll-row {
    --dir-cols: 12rem 6.5rem 1fr 11rem 1.5rem;
    scroll-margin-top: var(--space-16);
  }

  /* map pin jump target */
  .roll-row:target {
    border-color: var(--color-accent-primary);
    box-shadow: var(--shadow-hard-accent);
  }

  /* highlighted from hovering its pin on the map */
  .roll-row.is-pin-active {
    border-color: var(--color-accent-primary);
    outline: 1px solid var(--color-accent-primary);
  }

  .row-stock {
    font-weight: var(--font-weight-medium);
    color: var(--color-accent-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .row-stock[data-type='bw'] {
    color: var(--color-text-secondary);
  }

  .row-title {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .row-location {
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .roll-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto auto;
      gap: var(--space-1) var(--space-3);
    }

    .row-stock,
    .row-date {
      grid-row: 1;
    }

    .row-date {
      justify-self: end;
    }

    .row-title {
      grid-column: 1 / -1;
    }

    .row-location {
      grid-row: 3;
      grid-column: 1 / -1;
    }

    .row-arrow {
      display: none;
    }
  }
</style>
