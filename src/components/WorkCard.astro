---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  work: CollectionEntry<'work'>;
  index?: number;
}

const { work, index = 0 } = Astro.props;
const { title, description, category, tags, cover } = work.data;

const categoryColors = {
  dev: 'var(--color-accent-tertiary)',
  art: 'var(--color-accent-secondary)',
  photography: 'var(--color-accent-primary)',
};
---

<a href={`/work/${work.slug}`} class="work-card" style={`--delay: ${index * 0.1}s`}>
  <div class="card-image">
    {cover ? (
      <Image 
        src={cover} 
        alt={title}
        width={600}
        height={400}
        class="cover-image"
      />
    ) : (
      <div class="placeholder-image">
        <span class="placeholder-icon">{category === 'dev' ? '⚡' : category === 'art' ? '🎨' : '📷'}</span>
      </div>
    )}
    <div class="card-overlay">
      <span class="view-text">View</span>
    </div>
  </div>
  
  <div class="card-content">
    <span class="category" style={`--category-color: ${categoryColors[category]}`}>
      {category}
    </span>
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    
    {tags.length > 0 && (
      <div class="tags">
        {tags.slice(0, 3).map(tag => (
          <span class="tag">{tag}</span>
        ))}
        {tags.length > 3 && <span class="tag more">+{tags.length - 3}</span>}
      </div>
    )}
  </div>
</a>

<style>
  .work-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
    text-decoration: none;
    animation: fadeInUp var(--transition-slow) backwards;
    animation-delay: var(--delay);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card {
      animation: none;
      opacity: 1;
    }
  }
  
  .work-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  
  /* Image */
  .card-image {
    position: relative;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--color-bg-tertiary);
  }
  
  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }
  
  .work-card:hover .cover-image {
    transform: scale(1.05);
  }
  
  .placeholder-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-bg-tertiary), var(--color-bg-elevated));
  }
  
  .placeholder-icon {
    font-size: 3rem;
    opacity: 0.5;
  }
  
  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-base);
  }
  
  .work-card:hover .card-overlay {
    opacity: 1;
  }
  
  .view-text {
    color: white;
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-sm);
    text-transform: lowercase;
    letter-spacing: 0.02em;
    padding: var(--space-2) var(--space-4);
    border: 1px solid white;
    border-radius: var(--radius-full);
    transform: translateY(10px);
    transition: transform var(--transition-base);
  }
  
  .work-card:hover .view-text {
    transform: translateY(0);
  }
  
  /* Content */
  .card-content {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  
  .category {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    text-transform: lowercase;
    letter-spacing: 0.02em;
    color: var(--category-color);
  }
  
  .card-title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-primary);
    margin: 0;
    transition: color var(--transition-fast);
  }
  
  .work-card:hover .card-title {
    color: var(--color-accent-primary);
  }
  
  .card-description {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: var(--line-height-base);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  /* Tags */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  
  .tag {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    background: var(--color-bg-tertiary);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }
  
  .tag.more {
    color: var(--color-accent-primary);
    background: transparent;
  }
</style>
