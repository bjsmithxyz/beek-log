---
import type { CollectionEntry } from 'astro:content';
import { formatListDate } from '../lib/dates';

interface Props {
  work: CollectionEntry<'work'>;
  showDescription?: boolean;
}

const { work, showDescription = true } = Astro.props;
const { title, description, category, date } = work.data;

const formattedDate = formatListDate(date);
const categoryClass = `tag-${category}`;
---

<a href={`/work/${work.id}/`} class="dir-row work-row" data-category={category}>
  <span class={`row-tag ${categoryClass}`}>[{category}]</span>
  <span class="row-date">{formattedDate}</span>
  <span class="row-slug">{work.id}</span>
  {showDescription && (
    <span class="row-desc">{description}</span>
  )}
  <span class="row-arrow" aria-hidden="true">→</span>
</a>

<style>
  .work-row {
    --dir-cols: 5rem 6.5rem 1fr auto 1.5rem;
  }

  .row-tag {
    font-weight: var(--font-weight-medium);
    text-transform: lowercase;
  }

  .row-slug {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
  }

  .row-desc {
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .work-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: var(--space-1) var(--space-3);
    }

    .row-tag,
    .row-date {
      grid-row: 1;
    }

    .row-date {
      justify-self: end;
    }

    .row-slug {
      grid-column: 1 / -1;
    }

    .row-desc {
      display: none;
    }

    .row-arrow {
      grid-row: 1;
      grid-column: 2;
    }
  }
</style>
