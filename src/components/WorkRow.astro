---
import type { CollectionEntry } from 'astro:content';

interface Props {
  work: CollectionEntry<'work'>;
  showDescription?: boolean;
}

const { work, showDescription = true } = Astro.props;
const { title, description, category, date } = work.data;

const formattedDate = date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const categoryClass = `tag-${category}`;
---

<a href={`/work/${work.id}/`} class="work-row" data-category={category}>
  <span class={`row-tag ${categoryClass}`}>[{category}]</span>
  <span class="row-date">{formattedDate}</span>
  <span class="row-slug">{work.id}</span>
  {showDescription && (
    <span class="row-desc">{description}</span>
  )}
  <span class="row-arrow" aria-hidden="true">→</span>
</a>

<style>
  .work-row {
    display: grid;
    grid-template-columns: 5rem 6.5rem 1fr auto 1.5rem;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    margin-top: -1px;
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: background var(--transition-fast);
  }

  .work-row:first-child {
    margin-top: 0;
  }

  .work-row:hover {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
  }

  .work-row:hover .row-arrow {
    color: var(--color-accent-primary);
  }

  .row-tag {
    font-weight: var(--font-weight-medium);
    text-transform: lowercase;
  }

  .row-date {
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .row-slug {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-medium);
  }

  .row-desc {
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .row-arrow {
    color: var(--color-text-muted);
    text-align: right;
    transition: color var(--transition-fast);
  }

  @media (max-width: 768px) {
    .work-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: var(--space-1) var(--space-3);
    }

    .row-tag,
    .row-date {
      grid-row: 1;
    }

    .row-date {
      justify-self: end;
    }

    .row-slug {
      grid-column: 1 / -1;
    }

    .row-desc {
      display: none;
    }

    .row-arrow {
      grid-row: 1;
      grid-column: 2;
    }
  }
</style>
