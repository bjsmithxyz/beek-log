---
// Full-screen lightbox shared by work galleries and photo contact sheets.
// Any <img data-lightbox> on the page participates. Optional data attributes:
//   data-full    — larger image URL to show instead of the thumbnail src
//   data-caption — caption line (falls back to alt text before " - ")
//   data-meta    — small metadata line under the caption (film stock, frame, …)
---

<div id="lightbox" class="lightbox" aria-hidden="true">
  <button class="lightbox-close" aria-label="Close lightbox">&times;</button>

  <button class="lightbox-nav lightbox-prev" aria-label="Previous image">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>

  <button class="lightbox-nav lightbox-next" aria-label="Next image">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>

  <div class="lightbox-content">
    <img id="lightbox-img" src="" alt="" />
    <div class="lightbox-loading" aria-hidden="true">loading…</div>
    <p id="lightbox-caption"></p>
    <p id="lightbox-meta"></p>
  </div>
</div>

<script>
  function setupLightbox() {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxCaption = document.getElementById('lightbox-caption');
    const lightboxMeta = document.getElementById('lightbox-meta');
    const closeBtn = document.querySelector('.lightbox-close');
    const prevBtn = document.querySelector('.lightbox-prev');
    const nextBtn = document.querySelector('.lightbox-next');
    const galleryItems = document.querySelectorAll('[data-lightbox]') as NodeListOf<HTMLImageElement>;

    if (!lightbox || !lightboxImg || !lightboxCaption || !lightboxMeta || !closeBtn || !prevBtn || !nextBtn) return;

    let currentIndex = 0;

    const updateLightbox = (index: number) => {
      currentIndex = index;
      const item = galleryItems[currentIndex];
      if (!item) return;

      lightbox.classList.add('is-loading');
      lightboxImg.onload = () => lightbox.classList.remove('is-loading');
      lightboxImg.onerror = () => lightbox.classList.remove('is-loading');
      lightboxImg.src = item.dataset.full || item.src;
      // cached/same-source images may not fire onload — clear immediately
      if (lightboxImg.complete && lightboxImg.naturalWidth) lightbox.classList.remove('is-loading');
      lightboxImg.alt = item.alt;
      lightboxCaption.textContent = item.dataset.caption ?? item.alt.split(' - ')[0];
      lightboxMeta.textContent = item.dataset.meta ?? '';
    };

    const navigate = (direction: number) => {
      let nextIndex = currentIndex + direction;
      if (nextIndex < 0) nextIndex = galleryItems.length - 1;
      if (nextIndex >= galleryItems.length) nextIndex = 0;
      updateLightbox(nextIndex);
    };

    galleryItems.forEach((item, index) => {
      item.addEventListener('click', () => {
        updateLightbox(index);
        lightbox.classList.add('active');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      });
    });

    const closeLightbox = () => {
      lightbox.classList.remove('active');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setTimeout(() => {
        lightboxImg.src = '';
      }, 300);
    };

    closeBtn.addEventListener('click', closeLightbox);
    prevBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      navigate(-1);
    });
    nextBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      navigate(1);
    });

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target === document.querySelector('.lightbox-content')) {
        closeLightbox();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('active')) return;

      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
    });
  }

  document.addEventListener('astro:page-load', setupLightbox);
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    padding: var(--space-8);
  }

  .lightbox.active {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    transform: scale(0.95);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .lightbox.active .lightbox-content {
    transform: scale(1);
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: calc(90vh - 80px);
    object-fit: contain;
    border: 1px solid var(--color-border);
  }

  .lightbox-loading {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-family);
    font-size: var(--font-size-sm);
    letter-spacing: 0.18em;
    color: var(--color-accent-primary);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
    pointer-events: none;
    display: none;
    animation: lightbox-blink 1s steps(2, start) infinite;
  }

  .lightbox.is-loading .lightbox-loading {
    display: block;
  }

  .lightbox.is-loading #lightbox-img {
    opacity: 0.3;
  }

  @keyframes lightbox-blink {
    50% { opacity: 0.3; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox-loading { animation: none; }
  }

  .lightbox-content p {
    color: white;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-medium);
    margin: 0;
    text-align: center;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .lightbox-content #lightbox-meta {
    font-size: var(--font-size-xs);
    color: #999999;
    letter-spacing: 0.15em;
  }

  .lightbox-content #lightbox-meta:empty {
    display: none;
  }

  .lightbox-close {
    position: absolute;
    top: var(--space-8);
    right: var(--space-8);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    cursor: pointer;
    z-index: 10001;
    transition: all var(--transition-fast);
  }

  .lightbox-close:hover {
    background: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    color: var(--color-bg-primary);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10001;
    transition: all var(--transition-base);
  }

  .lightbox-nav:hover {
    background: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    color: var(--color-bg-primary);
  }

  .lightbox-prev {
    left: var(--space-8);
  }

  .lightbox-next {
    right: var(--space-8);
  }

  @media (max-width: 768px) {
    .lightbox {
      padding: var(--space-4);
    }
    .lightbox-close {
      top: var(--space-4);
      right: var(--space-4);
      width: 40px;
      height: 40px;
      font-size: 1.5rem;
    }
    .lightbox-nav {
      width: 44px;
      height: 44px;
      background: rgba(0, 0, 0, 0.5);
      border-color: rgba(255, 255, 255, 0.2);
    }
    .lightbox-prev {
      left: var(--space-4);
    }
    .lightbox-next {
      right: var(--space-4);
    }
  }
</style>
