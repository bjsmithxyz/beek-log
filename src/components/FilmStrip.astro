---
// One strip of a contact sheet: sprocket holes, film-edge markings and up to
// ~6 frames. The film base stays near-black in both themes (it's an object,
// not UI); sprocket holes show the page background, as if punched through.
import { Image, getImage } from 'astro:assets';

interface Photo {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  photos: Photo[];
  stockName: string;
  stockType: 'color' | 'bw';
  startFrame?: number;
  meta?: string;
}

const { photos, stockName, stockType, startFrame = 1, meta = '' } = Astro.props;

// colour negative edge print is orange; B&W rebate text is grey
const edgeColor = stockType === 'bw' ? 'var(--color-text-secondary)' : 'var(--color-accent-secondary)';

const fullImages = await Promise.all(
  photos.map((p) => getImage({ src: p.src, width: 2048 }))
);
---

<div class="film-strip" style={`--edge-color: ${edgeColor}`}>
  <div class="sprockets" aria-hidden="true"></div>
  <div class="edge-markings" aria-hidden="true">
    <span class="stock-name">{stockName.toUpperCase()}</span>
    <span class="arrows">▸▸</span>
    <span class="frame-range">{startFrame}–{startFrame + photos.length - 1}</span>
  </div>
  <div class="frames">
    {photos.map((p, i) => (
      <figure class="frame">
        <Image
          src={p.src}
          alt={p.alt}
          width={400}
          height={267}
          class="frame-img"
          loading="lazy"
          data-lightbox
          data-full={fullImages[i].src}
          data-caption={p.caption ?? p.alt}
          data-meta={`${stockName.toUpperCase()} · ${startFrame + i}A${meta ? ` · ${meta}` : ''}`}
        />
        <figcaption class="frame-no">
          <span>{startFrame + i}</span>
          <span>{startFrame + i}A</span>
        </figcaption>
      </figure>
    ))}
  </div>
  <div class="sprockets" aria-hidden="true"></div>
</div>

<style>
  .film-strip {
    background: #161412;
    border: 1px solid var(--color-border);
    padding: 3px 0;
    margin-bottom: var(--space-4);
  }

  .sprockets {
    height: 12px;
    margin: 3px 10px;
    background-image: repeating-linear-gradient(
      to right,
      transparent 0 7px,
      var(--color-bg-primary) 7px 17px,
      transparent 17px 24px
    );
  }

  .edge-markings {
    display: flex;
    gap: var(--space-4);
    padding: 1px 14px 3px;
    font-size: var(--font-size-xs);
    letter-spacing: 0.18em;
    color: var(--edge-color);
    user-select: none;
    white-space: nowrap;
    overflow: hidden;
  }

  .frame-range {
    margin-left: auto;
  }

  .frames {
    display: flex;
    gap: 6px;
    padding: 2px 10px;
    overflow-x: auto;
    scrollbar-width: thin;
  }

  .frame {
    margin: 0;
    flex: 0 0 clamp(130px, 18vw, 200px);
  }

  .frame-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    cursor: pointer;
    border: 1px solid #000;
  }

  .frame-no {
    display: flex;
    justify-content: space-between;
    font-size: var(--font-size-xs);
    color: var(--edge-color);
    letter-spacing: 0.1em;
    padding: 2px 2px 0;
    user-select: none;
  }
</style>
