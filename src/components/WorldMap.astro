---
// Dot-matrix world map in the site's terminal aesthetic. The land mask is a
// precomputed 240x120 grid (see scripts/generate-world-dots.mjs); shoot
// locations are plotted with an equirectangular projection. Pins are anchors
// that jump to the roll list below; a small script cross-highlights each pin
// with its roll row on hover and lifts the hovered pin above its neighbours.
import dots from '../data/world-dots.json';
import type { Pin } from '../data/locations';

interface Props {
  pins: Pin[];
}

const { pins } = Astro.props;

// Projection / viewBox space. Kept at 240x120 regardless of the land-mask
// resolution so pin and tooltip geometry below is unaffected.
const COLS = 240;
const ROWS = 120;

// The land-mask grid is finer than the viewBox; scale each cell into 240x120.
const grid = dots as string[];
const GRID_ROWS = grid.length;
const GRID_COLS = grid[0].length;
const cellW = COLS / GRID_COLS;
const cellH = ROWS / GRID_ROWS;
const dotR = +(cellW * 0.4).toFixed(2);

const project = (lat: number, lng: number) => ({
  x: +(((lng + 180) / 360) * COLS).toFixed(1),
  y: +(((90 - lat) / 180) * ROWS).toFixed(1),
});

// Tooltip geometry, in viewBox units. Monospace advance ≈ 0.6em. Every box gets
// the same width — the widest line across all pins — so tooltips are uniform;
// the title sits on top with each sub-region stacked on its own line below.
// Sizes are in viewBox units, so on-screen text scales with map width. The map
// is ~2.6x narrower on mobile than desktop, so these are tuned up for mobile
// legibility; desktop tooltips render larger but they're transient hover popups.
const TT = {
  fontSize: 6, // title line: "Label — N frames"
  subSize: 4.6, // sub-region lines
  padX: 2.6, // left/right inner padding
  padTop: 2.4,
  padBottom: 2.2,
  titleGap: 2.2, // title baseline to first sub-region
  lineH: 5.2, // per sub-region line height
};

const titleFor = (p: Pin) => `${p.label} — ${p.count} ${p.count === 1 ? 'frame' : 'frames'}`;

const tooltipWidth =
  Math.max(
    ...pins.map((p) =>
      Math.max(
        titleFor(p).length * TT.fontSize * 0.6,
        // sub-region lines carry a "· " bullet prefix (+2 chars)
        ...p.members.map((m) => (m.length + 2) * TT.subSize * 0.6)
      )
    )
  ) +
  TT.padX * 2;
---

<svg
  viewBox="0 0 240 120"
  class="world-map"
  role="img"
  aria-label={`Map of shoot locations: ${pins.map((p) => p.label).join(', ')}`}
>
  {grid.flatMap((row, gy) =>
    [...row].map((c, gx) =>
      c === '1' ? (
        <circle
          cx={+((gx + 0.5) * cellW).toFixed(1)}
          cy={+((gy + 0.5) * cellH).toFixed(1)}
          r={dotR}
          class="dot"
        />
      ) : null
    )
  )}
  {pins.map((p) => {
    const { x, y } = project(p.lat, p.lng);
    const title = titleFor(p);
    const width = tooltipWidth;
    const rectH =
      TT.padTop +
      TT.fontSize +
      (p.members.length ? TT.titleGap + TT.lineH * p.members.length : 0) +
      TT.padBottom;
    const rectX = Math.min(Math.max(x - width / 2, 1), COLS - width - 1);
    const rectY = Math.max(1, y - 3 - rectH);
    const cx = rectX + width / 2;
    return (
      <a href={`#roll-${p.slug}`} class="pin-link" aria-label={title} data-slugs={p.slugs.join(' ')}>
        <circle cx={x} cy={y} r="3.4" class="pin-halo" />
        <circle cx={x} cy={y} r="1" class="pin" />
        <g class="tooltip" aria-hidden="true" data-cx={cx} data-y={rectY} data-h={rectH} data-w={width}>
          <rect x={rectX} y={rectY} width={width} height={rectH} rx="0.8" class="tooltip-box" />
          <text
            x={rectX + TT.padX}
            y={rectY + TT.padTop + TT.fontSize / 2}
            font-size={TT.fontSize}
            text-anchor="start"
            dominant-baseline="central"
            class="tooltip-text"
          >{title}</text>
          {p.members.map((m, i) => (
            <text
              x={rectX + TT.padX}
              y={rectY + TT.padTop + TT.fontSize + TT.titleGap + TT.lineH * i + TT.lineH / 2}
              font-size={TT.subSize}
              text-anchor="start"
              dominant-baseline="central"
              class="tooltip-sub"
            >{`· ${m}`}</text>
          ))}
        </g>
      </a>
    );
  })}
</svg>

<script>
  function setupMapHover() {
    const svg = document.querySelector('.world-map');
    if (!svg) return;

    // bring a pin to the end of the SVG so its tooltip paints above neighbours
    const lift = (pin: Element) => svg.appendChild(pin);

    const setPin = (pin: Element, on: boolean) => {
      pin.classList.toggle('is-active', on);
      if (on) lift(pin);
    };

    // A single roll can light up several nearby pins at once (e.g. a trip across
    // Thailand + Vietnam). Their tooltips are each centred on their own pin and
    // would overlap, so nudge colliding boxes downward into a clean stack.
    const num = (el: Element, k: string) => +((el as HTMLElement).dataset[k] || 0);
    const relayoutTooltips = () => {
      const all = svg.querySelectorAll<SVGGElement>('.tooltip');
      all.forEach((t) => t.removeAttribute('transform'));
      const boxes = [...svg.querySelectorAll<SVGGElement>('.pin-link.is-active .tooltip')]
        .map((el) => ({ el, cx: num(el, 'cx'), y: num(el, 'y'), h: num(el, 'h'), w: num(el, 'w') }))
        .sort((a, b) => a.y - b.y); // topmost first; later boxes cascade below
      const gap = 1;
      const placed: typeof boxes = [];
      for (const b of boxes) {
        let y = b.y;
        for (const p of placed) {
          const overlapX = Math.abs(b.cx - p.cx) < (b.w + p.w) / 2;
          if (overlapX && y < p.y + p.h + gap && y + b.h > p.y) y = p.y + p.h + gap;
        }
        if (y !== b.y) b.el.setAttribute('transform', `translate(0 ${(y - b.y).toFixed(2)})`);
        placed.push({ ...b, y });
      }
    };

    // A pin can stand for several rolls (same country grouped into one pin), and
    // a roll can span several pins (photos in different countries). Cross-
    // highlight every matching counterpart, not just one.
    const rowsForPin = (pin: Element) =>
      ((pin as HTMLElement).dataset.slugs || '').split(' ').filter(Boolean)
        .map((s) => document.getElementById(`roll-${s}`))
        .filter((r): r is HTMLElement => !!r);

    svg.querySelectorAll<HTMLElement>('.pin-link').forEach((pin) => {
      const rows = rowsForPin(pin);
      const on = () => { setPin(pin, true); rows.forEach((r) => r.classList.add('is-pin-active')); relayoutTooltips(); };
      const off = () => { setPin(pin, false); rows.forEach((r) => r.classList.remove('is-pin-active')); relayoutTooltips(); };
      pin.addEventListener('mouseenter', on);
      pin.addEventListener('mouseleave', off);
      pin.addEventListener('focus', on);
      pin.addEventListener('blur', off);
    });

    document.querySelectorAll<HTMLElement>('.roll-row[data-slug]').forEach((row) => {
      const slug = row.dataset.slug;
      // ~= matches the slug as one whitespace-separated token within data-slugs
      const pins = svg.querySelectorAll(`.pin-link[data-slugs~="${slug}"]`);
      row.addEventListener('mouseenter', () => { pins.forEach((p) => setPin(p, true)); relayoutTooltips(); });
      row.addEventListener('mouseleave', () => { pins.forEach((p) => setPin(p, false)); relayoutTooltips(); });
    });
  }

  document.addEventListener('astro:page-load', setupMapHover);
</script>

<style>
  .world-map {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    padding: var(--space-2);
  }

  .dot {
    fill: var(--color-border-strong);
  }

  .pin {
    fill: var(--color-accent-primary);
    transition: filter 0.12s ease;
  }

  .pin-halo {
    fill: var(--color-accent-primary);
    opacity: 0;
    transition: opacity 0.12s ease;
  }

  .pin-link {
    cursor: pointer;
  }

  /* hover/focus the pin directly, or .is-active set by the row-hover script */
  .pin-link:hover .pin-halo,
  .pin-link:focus .pin-halo,
  .pin-link.is-active .pin-halo {
    opacity: 0.3;
  }

  .pin-link:hover .pin,
  .pin-link:focus .pin,
  .pin-link.is-active .pin {
    filter: brightness(0.82);
  }

  .tooltip {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.12s ease;
  }

  .pin-link:hover .tooltip,
  .pin-link:focus .tooltip,
  .pin-link.is-active .tooltip {
    opacity: 1;
  }

  .tooltip-box {
    fill: var(--color-bg-primary);
    stroke: var(--color-border-strong);
    stroke-width: 0.3;
  }

  .tooltip-text {
    fill: var(--color-text-primary);
    font-family: monospace;
  }

  .tooltip-sub {
    fill: var(--color-text-muted);
    font-family: monospace;
  }
</style>
