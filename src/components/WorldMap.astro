---
// Dot-matrix world map in the site's terminal aesthetic. The land mask is a
// precomputed 240x120 grid (see scripts/generate-world-dots.mjs); shoot
// locations are plotted with an equirectangular projection. Pins are plain
// anchors that jump to the roll list below — no client JS.
import dots from '../data/world-dots.json';

export interface Pin {
  slug: string;
  name: string;
  lat: number;
  lng: number;
  count: number;
}

interface Props {
  pins: Pin[];
}

const { pins } = Astro.props;

const COLS = 240;
const ROWS = 120;

// Antarctica's ice reads as ocean to the land mask, leaving a stray spray of
// dots; drop everything south of -60° lat (no shoot locations down there).
const ANTARCTICA_CUTOFF_ROW = Math.round(((90 - -60) / 180) * ROWS);

const project = (lat: number, lng: number) => ({
  x: +(((lng + 180) / 360) * COLS).toFixed(1),
  y: +(((90 - lat) / 180) * ROWS).toFixed(1),
});
---

<svg
  viewBox="0 0 240 120"
  class="world-map"
  role="img"
  aria-label={`Map of shoot locations: ${pins.map((p) => p.name).join(', ')}`}
>
  {(dots as string[]).flatMap((row, y) =>
    y >= ANTARCTICA_CUTOFF_ROW
      ? []
      : [...row].map((c, x) =>
          c === '1' ? <circle cx={x + 0.5} cy={y + 0.5} r="0.4" class="dot" /> : null
        )
  )}
  {pins.map((p) => {
    const { x, y } = project(p.lat, p.lng);
    const label = `${p.name} — ${p.count} ${p.count === 1 ? 'frame' : 'frames'}`;
    const fontSize = 3.2;
    const rectW = label.length * fontSize * 0.6 + 4;
    const rectH = fontSize + 3.2;
    const rectX = Math.min(Math.max(x - rectW / 2, 1), COLS - rectW - 1);
    const rectY = Math.max(1, y - 3 - rectH);
    return (
      <a href={`#roll-${p.slug}`} class="pin-link" aria-label={label}>
        <circle cx={x} cy={y} r="4.8" class="pin-halo" />
        <circle cx={x} cy={y} r="1" class="pin" />
        <g class="tooltip" aria-hidden="true">
          <rect x={rectX} y={rectY} width={rectW} height={rectH} rx="0.8" class="tooltip-box" />
          <text
            x={rectX + rectW / 2}
            y={rectY + rectH / 2}
            font-size={fontSize}
            text-anchor="middle"
            dominant-baseline="central"
            class="tooltip-text"
          >{label}</text>
        </g>
      </a>
    );
  })}
</svg>

<style>
  .world-map {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    padding: var(--space-2);
  }

  .dot {
    fill: var(--color-border-strong);
  }

  .pin {
    fill: var(--color-accent-primary);
  }

  .pin-halo {
    fill: var(--color-accent-primary);
    opacity: 0;
    transition: opacity 0.12s ease;
  }

  .pin-link {
    cursor: pointer;
  }

  .pin-link:hover .pin-halo,
  .pin-link:focus .pin-halo {
    opacity: 0.4;
  }

  .tooltip {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.12s ease;
  }

  .pin-link:hover .tooltip,
  .pin-link:focus .tooltip {
    opacity: 1;
  }

  .tooltip-box {
    fill: var(--color-bg-primary);
    stroke: var(--color-border-strong);
    stroke-width: 0.3;
  }

  .tooltip-text {
    fill: var(--color-text-primary);
    font-family: monospace;
  }
</style>
