---
// Dot-matrix world map in the site's terminal aesthetic. The land mask is a
// precomputed 240x120 grid (see scripts/generate-world-dots.mjs); shoot
// locations are plotted with an equirectangular projection. Pins are anchors
// that jump to the roll list below; a small script cross-highlights each pin
// with its roll row on hover and lifts the hovered pin above its neighbours.
import dots from '../data/world-dots.json';
import type { Pin } from '../data/locations';

interface Props {
  pins: Pin[];
}

const { pins } = Astro.props;

const COLS = 240;
const ROWS = 120;

// Antarctica's ice reads as ocean to the land mask, leaving a stray spray of
// dots; drop everything south of -60° lat (no shoot locations down there).
const ANTARCTICA_CUTOFF_ROW = Math.round(((90 - -60) / 180) * ROWS);

const project = (lat: number, lng: number) => ({
  x: +(((lng + 180) / 360) * COLS).toFixed(1),
  y: +(((90 - lat) / 180) * ROWS).toFixed(1),
});
---

<svg
  viewBox="0 0 240 120"
  class="world-map"
  role="img"
  aria-label={`Map of shoot locations: ${pins.map((p) => p.label).join(', ')}`}
>
  {(dots as string[]).flatMap((row, y) =>
    y >= ANTARCTICA_CUTOFF_ROW
      ? []
      : [...row].map((c, x) =>
          c === '1' ? <circle cx={x + 0.5} cy={y + 0.5} r="0.4" class="dot" /> : null
        )
  )}
  {pins.map((p) => {
    const { x, y } = project(p.lat, p.lng);
    const line1 = `${p.label} — ${p.count} ${p.count === 1 ? 'frame' : 'frames'}`;
    const line2 = p.members.join(' · ');
    // tooltip box sized in viewBox units: ~0.6 advance per monospace char, +4
    // horizontal padding; height = text + 3.2 (1.6 top/bottom) and, for two
    // lines, +1.4 inter-line gap. line1 sits ~1/3 down, line2 ~3/4 down.
    const fontSize = 3.2;
    const subSize = 2.6;
    const width = Math.max(line1.length * fontSize * 0.6, line2.length * subSize * 0.6) + 4;
    const rectH = (line2 ? fontSize + subSize + 1.4 : fontSize) + 3.2;
    const rectX = Math.min(Math.max(x - width / 2, 1), COLS - width - 1);
    const rectY = Math.max(1, y - 3 - rectH);
    const cx = rectX + width / 2;
    return (
      <a href={`#roll-${p.slug}`} class="pin-link" aria-label={line1} data-slug={p.slug}>
        <circle cx={x} cy={y} r="3.4" class="pin-halo" />
        <circle cx={x} cy={y} r="1" class="pin" />
        <g class="tooltip" aria-hidden="true">
          <rect x={rectX} y={rectY} width={width} height={rectH} rx="0.8" class="tooltip-box" />
          <text
            x={cx}
            y={rectY + (line2 ? rectH * 0.36 : rectH / 2)}
            font-size={fontSize}
            text-anchor="middle"
            dominant-baseline="central"
            class="tooltip-text"
          >{line1}</text>
          {line2 && (
            <text
              x={cx}
              y={rectY + rectH * 0.72}
              font-size={subSize}
              text-anchor="middle"
              dominant-baseline="central"
              class="tooltip-sub"
            >{line2}</text>
          )}
        </g>
      </a>
    );
  })}
</svg>

<script>
  function setupMapHover() {
    const svg = document.querySelector('.world-map');
    if (!svg) return;

    // bring a pin to the end of the SVG so its tooltip paints above neighbours
    const lift = (pin: Element) => svg.appendChild(pin);

    const setPin = (pin: Element, on: boolean) => {
      pin.classList.toggle('is-active', on);
      if (on) lift(pin);
    };

    svg.querySelectorAll<HTMLElement>('.pin-link').forEach((pin) => {
      const slug = pin.dataset.slug;
      const row = slug ? document.getElementById(`roll-${slug}`) : null;
      const on = () => { setPin(pin, true); row?.classList.add('is-pin-active'); };
      const off = () => { setPin(pin, false); row?.classList.remove('is-pin-active'); };
      pin.addEventListener('mouseenter', on);
      pin.addEventListener('mouseleave', off);
      pin.addEventListener('focus', on);
      pin.addEventListener('blur', off);
    });

    document.querySelectorAll<HTMLElement>('.roll-row[data-slug]').forEach((row) => {
      const slug = row.dataset.slug;
      const pins = svg.querySelectorAll(`.pin-link[data-slug="${slug}"]`);
      row.addEventListener('mouseenter', () => pins.forEach((p) => setPin(p, true)));
      row.addEventListener('mouseleave', () => pins.forEach((p) => setPin(p, false)));
    });
  }

  document.addEventListener('astro:page-load', setupMapHover);
</script>

<style>
  .world-map {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    padding: var(--space-2);
  }

  .dot {
    fill: var(--color-border-strong);
  }

  .pin {
    fill: var(--color-accent-primary);
    transition: filter 0.12s ease;
  }

  .pin-halo {
    fill: var(--color-accent-primary);
    opacity: 0;
    transition: opacity 0.12s ease;
  }

  .pin-link {
    cursor: pointer;
  }

  /* hover/focus the pin directly, or .is-active set by the row-hover script */
  .pin-link:hover .pin-halo,
  .pin-link:focus .pin-halo,
  .pin-link.is-active .pin-halo {
    opacity: 0.3;
  }

  .pin-link:hover .pin,
  .pin-link:focus .pin,
  .pin-link.is-active .pin {
    filter: brightness(0.82);
  }

  .tooltip {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.12s ease;
  }

  .pin-link:hover .tooltip,
  .pin-link:focus .tooltip,
  .pin-link.is-active .tooltip {
    opacity: 1;
  }

  .tooltip-box {
    fill: var(--color-bg-primary);
    stroke: var(--color-border-strong);
    stroke-width: 0.3;
  }

  .tooltip-text {
    fill: var(--color-text-primary);
    font-family: monospace;
  }

  .tooltip-sub {
    fill: var(--color-text-muted);
    font-family: monospace;
  }
</style>
